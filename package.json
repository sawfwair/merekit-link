{
  "name": "@merekit/link",
  "version": "0.1.0",
  "description": "Standalone MereKit link graph CLI for YAML-defined integrations, projects, role surfaces, and workspace bootstrap.",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "types": "dist/run.d.ts",
  "exports": {
    ".": {
      "types": "./dist/run.d.ts",
      "import": "./dist/run.js"
    }
  },
  "author": "MereKit contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sawfwair/merekit-link.git"
  },
  "bugs": {
    "url": "https://github.com/sawfwair/merekit-link/issues"
  },
  "homepage": "https://sawfwair.github.io/merekit-link/",
  "keywords": [
    "agent",
    "cli",
    "link-graph",
    "merekit",
    "policy",
    "workspace"
  ],
  "bin": {
    "mere-link": "dist/run.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "CODEBASE.md",
    "CONTRIBUTING.md",
    "DECISIONS.md",
    "docs/**/*.md",
    "docs/.vitepress/config.mts",
    "docs/.vitepress/theme",
    "README.md",
    "LICENSE",
    "NOTICE",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepack": "pnpm build",
    "check:node": "tsx scripts/check-node-version.ts",
    "build": "tsc -p tsconfig.json && chmod 755 dist/run.js",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:worker:test": "node --test docs-worker/*.test.mjs",
    "docs:worker:dry-run": "DOCS_BASE=/ pnpm docs:build && npx --yes wrangler@4.97.0 deploy -c wrangler.docs.jsonc --dry-run",
    "docs:deploy": "DOCS_BASE=/ pnpm docs:build && npx --yes wrangler@4.97.0 deploy -c wrangler.docs.jsonc",
    "lint": "eslint . --max-warnings=0",
    "test": "pnpm build && tsx --test test/*.test.ts",
    "coverage": "pnpm build && c8 --include='dist/**/*.js' --reporter=text --check-coverage --lines 80 --functions 80 --branches 70 tsx --test test/*.test.ts",
    "smoke": "pnpm build && node dist/run.js --version >/dev/null && node dist/run.js commands --json >/dev/null && node dist/run.js completion bash >/dev/null",
    "smoke:package": "pnpm build && tsx scripts/smoke-package.ts",
    "verify": "pnpm check:node && pnpm lint && pnpm check && pnpm test && pnpm coverage && pnpm smoke && pnpm smoke:package && pnpm docs:build && npm pack --dry-run --ignore-scripts",
    "release:check": "pnpm verify && pnpm audit --audit-level=low",
    "prepublishOnly": "pnpm release:check",
    "pack:dry": "pnpm verify"
  },
  "dependencies": {
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.5.2",
    "c8": "^11.0.0",
    "eslint": "^10.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitepress": "1.6.4",
    "vue": "^3.5.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.2",
      "esbuild": "0.25.12"
    }
  },
  "engines": {
    "node": ">=22 <26"
  },
  "packageManager": "pnpm@10.8.1"
}
